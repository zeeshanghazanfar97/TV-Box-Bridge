STREAM_PATH=tvbox
STREAM_WHEP_URL=
# Optional public HLS URL used inside the generated Jellyfin M3U playlist.
# Leave blank to derive http://<dashboard-host>:8888/<stream-path>/index.m3u8.
STREAM_HLS_URL=
LIVE_TV_CHANNEL_NAME=TV Box Live
LIVE_TV_CHANNEL_NUMBER=1
LIVE_TV_GROUP_TITLE=Live TV
# Set this to the Ubuntu server LAN IP when viewing from another computer.
WEBRTC_ADDITIONAL_HOSTS=

TVBOX_VIDEO_DEVICE=/dev/tvbox-video
TVBOX_AUDIO_DEVICE=plughw:CARD=<capture-card-id>,DEV=0
TVBOX_VIDEO_SIZE=1920x1080
TVBOX_FRAMERATE=30
TVBOX_INPUT_FORMAT=mjpeg
TVBOX_VIDEO_BITRATE=4500k
TVBOX_AUDIO_ENABLED=true

IR_BRIDGE_ENABLED=true
# Host path exposed by the udev rule. If testing manually, this can be /dev/ttyACM0.
IR_SERIAL_DEVICE=/dev/ir-pico
# Path used inside the dashboard container.
IR_SERIAL_PATH=/dev/ir-pico
IR_SERIAL_BAUD=115200
IR_SERIAL_TIMEOUT_MS=1400
IR_COMMAND_DELAY_MS=120
# Optional: set to ok if your box needs OK after typed channel sequences.
IR_CHANNEL_CONFIRM_COMMAND=

VIDEO_GID=44
AUDIO_GID=29
